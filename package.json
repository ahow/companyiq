{
  "name": "companyiq",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "description": "CompanyIQ - AI-powered company analysis platform for ESG and governance assessment",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:worker": "tsx watch server/worker.ts",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "cd client && pnpm run build",
    "build": "pnpm run build:server && pnpm run build:client",
    "start": "node dist/server/index.js",
    "worker": "node dist/server/worker.js",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "check": "tsc --noEmit -p tsconfig.server.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.34.0",
    "drizzle-zod": "^0.5.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.20.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "puppeteer-core": "^25.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "drizzle-kit": "^0.25.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  }
}
